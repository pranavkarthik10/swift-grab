{
  "name": "sim-grab-bridge",
  "private": true,
  "version": "0.1.8",
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "node dist/index.js",
    "build": "bun build ./src/index.ts --target=node --outdir ./dist --packages=external",
    "typecheck": "tsc --noEmit",
    "build:capture": "cd capture && swift build -c release",
    "postinstall": "bun run build:capture || echo '[bridge] Swift capture build failed — falling back to simctl screenshots. Run `cd bridge/capture && swift build -c release` to enable ScreenCaptureKit.'"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/ws": "^8.5.13",
    "typescript": "^5.6.3"
  }
}
