{
  "name": "sim-grab",
  "version": "0.1.2",
  "description": "Inspect and drive a live iOS Simulator from a browser with accessibility metadata for AI coding workflows.",
  "license": "MIT",
  "private": false,
  "type": "module",
  "bin": {
    "sim-grab": "./bin/sim-grab.js"
  },
  "files": [
    "bin",
    "bridge/src",
    "bridge/capture/Package.swift",
    "bridge/capture/Sources",
    "bridge/package.json",
    "shared",
    "web/index.html",
    "web/src",
    "web/package.json",
    "web/tsconfig.json",
    "web/vite.config.ts",
    "tsconfig.base.json",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pranavkarthik10/sim-grab.git"
  },
  "keywords": [
    "ios-simulator",
    "accessibility",
    "agents",
    "idb",
    "simctl",
    "cursor",
    "codex",
    "mobile-testing"
  ],
  "engines": {
    "bun": ">=1.1.0"
  },
  "workspaces": ["web", "bridge"],
  "scripts": {
    "start": "bun ./bin/sim-grab.js",
    "dev": "bun --filter sim-grab-web dev & bun --filter sim-grab-bridge dev & wait",
    "dev:web": "bun --filter sim-grab-web dev",
    "dev:bridge": "bun --filter sim-grab-bridge dev",
    "build:web": "bun --filter sim-grab-web build",
    "build:capture": "bun --filter sim-grab-bridge build:capture",
    "typecheck": "bun --filter '*' typecheck"
  },
  "dependencies": {
    "vite": "^5.4.10"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  }
}
